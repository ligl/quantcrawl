# -----------------------------------------------------------------------------
# Runtime environment (required)
# APP_ENV allowed values: dev | staging | prod
# -----------------------------------------------------------------------------
APP_ENV=dev

# -----------------------------------------------------------------------------
# Storage
# STORAGE_BACKEND allowed values: sqlite | postgres
# POSTGRES_DSN is conditionally required when STORAGE_BACKEND=postgres
# -----------------------------------------------------------------------------
STORAGE_BACKEND=sqlite
SQLITE_PATH=data/quantcrawl.db
POSTGRES_DSN=

# -----------------------------------------------------------------------------
# Distributed mode (Redis)
# REDIS_URL is conditionally required when DISTRIBUTED_ENABLED=true
# -----------------------------------------------------------------------------
DISTRIBUTED_ENABLED=false
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_DIR=logs
LOG_MAX_BYTES=20971520
LOG_BACKUP_COUNT=10

# -----------------------------------------------------------------------------
# Alerting - Email
# All fields below are conditionally required when ALERT_EMAIL_ENABLED=true:
# ALERT_EMAIL_TO, ALERT_EMAIL_FROM, SMTP_HOST, SMTP_PORT, SMTP_USER, SMTP_PASSWORD
# -----------------------------------------------------------------------------
ALERT_EMAIL_ENABLED=false
ALERT_EMAIL_TO=
ALERT_EMAIL_FROM=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# -----------------------------------------------------------------------------
# Alerting - Feishu
# ALERT_FEISHU_WEBHOOK is conditionally required when ALERT_FEISHU_ENABLED=true
# -----------------------------------------------------------------------------
ALERT_FEISHU_ENABLED=false
ALERT_FEISHU_WEBHOOK=

# -----------------------------------------------------------------------------
# Alerting - DingTalk
# ALERT_DINGTALK_WEBHOOK is conditionally required when ALERT_DINGTALK_ENABLED=true
# -----------------------------------------------------------------------------
ALERT_DINGTALK_ENABLED=false
ALERT_DINGTALK_WEBHOOK=

# -----------------------------------------------------------------------------
# Anti-bot defaults
# DEFAULT_UA_PLATFORM allowed values in current scaffold: desktop | mobile
# -----------------------------------------------------------------------------
DEFAULT_UA_PLATFORM=desktop

# -----------------------------------------------------------------------------
# Challenge providers (JSON)
# CHALLENGE_PROVIDER_REGISTRY format:
#   {"provider_ref":"pkg.module.ClassName"}
# CHALLENGE_PROVIDER_CONFIGS format:
#   {"provider_ref":{"kwarg":"value"}}
# Each provider_ref in CHALLENGE_PROVIDER_CONFIGS must exist in registry.
# -----------------------------------------------------------------------------
CHALLENGE_PROVIDER_REGISTRY={}
CHALLENGE_PROVIDER_CONFIGS={}
